{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Expo (QR code / Expo Go)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["start"],
      "port": 8081
    },
    {
      "name": "Expo Android",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "android"],
      "port": 8081
    },
    {
      "name": "Expo iOS",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "ios"],
      "port": 8081
    },
    {
      "name": "Expo Web",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "web"],
      "port": 19006
    }
  ]
}
